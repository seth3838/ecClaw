#!/usr/bin/env bash
set -uo pipefail

# Auto-push current branch to origin after each commit.
branch="$(git rev-parse --abbrev-ref HEAD)"
if [ "$branch" = "HEAD" ]; then
  echo "[post-commit] skip: detached HEAD (likely rebase/cherry-pick)"
  exit 0
fi

if ! git remote get-url origin >/dev/null 2>&1; then
  echo "[post-commit] skip: remote 'origin' not set"
  exit 0
fi

# Push and set upstream on first push if needed.
if ! git push -u origin "$branch"; then
  echo "[post-commit] warning: auto-push failed."
  echo "[post-commit] hint: configure GitHub auth (PAT/credential manager or SSH key), then run:"
  echo "  git push -u origin $branch"
fi
